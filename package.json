{
  "name": "aura-luxe-perfume",
  "version": "1.0.0",
  "description": "Premium Luxury Animated Perfume Store Monorepo",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run start --workspace=backend",
    "dev": "concurrently --kill-others \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "private": true
}
